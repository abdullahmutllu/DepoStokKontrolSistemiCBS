# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/depo

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=720

# --- AI (OpenRouter) — optional; app fully works without it ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Cheap default; free-tier models are dev/test only (~20 req/min rate limit).
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
AI_MAX_TOKENS=800
AI_DAILY_LIMIT=50

# --- Email (SMTP) — optional; falls back to console logging in dev ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=depo@localhost

# --- Background jobs ---
RUN_SCHEDULER=1
LOW_STOCK_CHECK_MINUTES=15
